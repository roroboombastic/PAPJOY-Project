# ==================== CRITICAL SECURITY NOTICE ====================
# ⚠️ NEVER commit this file or any .env/.env.production/.env.local to version control!
# ⚠️ Add .env* to .gitignore BEFORE committing
# ⚠️ Each environment (dev, staging, prod) needs unique values
# ⚠️ For production: use strong randomly generated secrets

# ==================== ENVIRONMENT ====================
NODE_ENV=development
LOG_LEVEL=debug

# ==================== SERVER ====================
PORT=3000
HTTPS_ENABLED=false
FORCE_HTTPS=false
TRUST_PROXY=false
APP_URL=http://localhost:3000

# ==================== JWT SECURITY ====================
# IMPORTANT: Generate strong random secrets
# Linux/Mac: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# PowerShell: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev_secret_key_CHANGE_THIS_IN_PRODUCTION
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=dev_refresh_secret_CHANGE_THIS_IN_PRODUCTION
JWT_REFRESH_EXPIRE=30d

# ==================== DATABASE ====================
# MongoDB (Local for development, Atlas for production)
MONGO_URI=mongodb://127.0.0.1:27017/papjoy
MONGO_FALLBACK_TO_LOCAL=true
LOCAL_MONGO_URI=mongodb://127.0.0.1:27017/papjoy

# ==================== CORS CONFIGURATION ====================
# Production: Specific domain(s) only
# Development: * (for localhost testing)
CORS_ORIGIN=*

# ==================== GOOGLE OAUTH ====================
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ==================== STRIPE PAYMENT ====================
STRIPE_SECRET_KEY=sk_test_YOUR_TEST_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_test_YOUR_WEBHOOK_SECRET_HERE

# ==================== RAZORPAY PAYMENT (India) ====================
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_HERE
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET_HERE
RAZORPAY_CURRENCY=INR

# ==================== PAYPAL PAYMENT ====================
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=YOUR_PAYPAL_SANDBOX_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_SANDBOX_SECRET
PAYPAL_SUCCESS_URL=http://localhost:3000/success
PAYPAL_CANCEL_URL=http://localhost:3000/checkout

# ==================== SSL/TLS (Reverse Proxy Recommended) ====================
# If using Nginx/Apache in front of Node: set these at proxy level
# For direct HTTPS in Node:
# SSL_CERT_PATH=/path/to/certificate.crt
# SSL_KEY_PATH=/path/to/private.key
